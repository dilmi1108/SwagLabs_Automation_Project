<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Login Test Suite" parallel="false" thread-count="1">
    <listeners>
        <listener class-name="tests.listeners.TestListener"/>
    </listeners>

    <test name="Chrome - Login Functionality Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Inventory Page Functionality Tests">
        <classes>
            <class name="tests.InventoryTest"/>
        </classes>
    </test>

    <!-- Uncomment to run on multiple browsers
    <test name="Firefox - Login Functionality Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Edge - Login Functionality Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>
    -->
</suite>
