<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Automation Suite" parallel="classes" thread-count="4">
    <listeners>
        <listener class-name="tests.listeners.TestListener"/>
    </listeners>

    <test name="SauceDemo Functional Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.InventoryTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutTest"/>
            <class name="tests.NavigationTest"/>
            <class name="tests.ProblemUserTest"/>
        </classes>
    </test>
</suite>
